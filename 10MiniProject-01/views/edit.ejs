<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="min-h-screen w-full bg-zinc-900 p-10">
        <div class="w-full flex justify-end"> 
            <a class="bg-red-500 inline-block px-3 py-2 w-40 py-2 block rounded-md mb-5 text-sm text-center text-white" href="/logout">LogOut</a>
        </div>
       
        <h5 class="text-white mb-5">Edit your Post.</h5>
        <form action="/update/<%= post._id %>" method="post">
            <textarea
                class="block bg-zinc-800 resize-none rounded-md text-white p-3 border-yellow-600 outline-none w-1/3"
                placeholder="What's on your mind?" name="content"><%= post.content%></textarea>
            <input class="bg-yellow-500 text-black px-3 w-40 py-2 block rounded-md mt-2 text-sm" type="submit"
                value="Update Post">
        </form>
      
    </div>

</body>

</html>