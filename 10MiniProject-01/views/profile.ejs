<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="min-h-screen w-full bg-zinc-900 p-10">
        <div class="w-full flex justify-end">
            <a class="bg-red-500 inline-block px-3 py-2 w-40 py-2 block rounded-md mb-5 text-sm text-center text-white"
                href="/logout">LogOut</a>
        </div>
        <div class="flex gap-3 items-start">
            <div class="w-10 h-10 overflow-hidden  rounded-md">
                <a href="/profile/upload"> <img class="w-full h-full object-cover" src="/images/uploads/<%= user.profilepic %>" alt="">
                </a>
            </div>
            <h2 class="text-white text-3xl"><span class="font-light">Hello</span>
                <%= user.name%>👋
            </h2>
        </div>
        <h5 class="text-white mb-5">You can Create a New Post.</h5>
        <form action="/post" method="post">
            <textarea
                class="block bg-zinc-800 resize-none rounded-md text-white p-3 border-yellow-600 outline-none w-1/3"
                placeholder="What's on your mind?" name="content"></textarea>
            <input class="bg-blue-500 px-3 w-40 py-2 block rounded-md mt-2 text-sm text-white" type="submit"
                value="Create Post">
        </form>
        <div class="posts mt-20">
            <h3 class="text-zinc-400">Your Posts.</h3>
            <div class="postcontainer text-white mt-5">
                <% user.posts.forEach(function(post){%>
                    <div class="post mb-4 w-1/3 p-4 rounded-md border-[1px] border-zinc-400">
                        <h4 class="text-blue-500 mb-2">@<%= user.username%>
                        </h4>
                        <p class="text-sm tracking-tight">
                            <%= post.content %>
                        </p>
                        <small class="mt-2 inline-block">
                            <%= post.likes.length %>
                        </small>
                        <div class="btns flex gap-4 mt-1">
                            <a class="text-blue-500" href="/like/<%= post._id %>">
                                <%= post.likes.indexOf(user._id)===-1 ? "Like" : "Unlike" %>
                            </a>
                            <a class="text-zinc-400" href="/edit/<%= post._id%>">edit</a>
                        </div>
                    </div>
                    <% })%>


            </div>
        </div>
    </div>

</body>

</html>