<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="min-h-screen bg-zinc-900  flex items-center justify-center  p-10">
        <form class="flex flex-col gap-3 w-1/4" action="/register" method="post">
            <h2 class="text-white text-3xl mb-5">Create User</h2>
            <input class="bg-transparent rounded-md text-white outline-none border-2 px-3 py-2 border-zinc-800 text-white" type="name" placeholder="name" name="name">
            <input class="bg-transparent rounded-md text-white outline-none border-2 px-3 py-2 border-zinc-800 text-white" type="username" placeholder="username" name="username">
            <input class="bg-transparent rounded-md text-white outline-none border-2 px-3 py-2 border-zinc-800 text-white" type="email" placeholder="email" name="email">
            <input class="bg-transparent rounded-md text-white outline-none border-2 px-3 py-2 border-zinc-800 text-white" type="password" placeholder="password" name="password">
            <input class="bg-transparent rounded-md text-white outline-none border-2 px-3 py-2 border-zinc-800 text-white" type="number" placeholder="age" name="age">
            <input class="px-3 py-2 bg-blue-500 rounded-md text-white" type="submit" value="Create User">
        </form>

    </div>
</body>
</html>