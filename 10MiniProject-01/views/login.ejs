<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="min-h-screen bg-zinc-900  flex items-center justify-center  p-10">
        <form class="flex flex-col gap-3 w-1/4" action="/login" method="post">
            <h2 class="text-white text-3xl mb-5">Login Your Account</h2>
            <input class="bg-transparent rounded-md text-white outline-none border-2 px-3 py-2 border-zinc-800 text-white" type="email" placeholder="email" name="email">
            <input class="bg-transparent rounded-md text-white outline-none border-2 px-3 py-2 border-zinc-800 text-white" type="password" placeholder="password" name="password">
            <input class="px-3 py-2 bg-blue-500 rounded-md text-white" type="submit" value="Log In">
            <div class="flex gap-2">
                <h5 class="text-white">Don't have an Account?</h5> <a class="text-blue-400" href="/">Register</a>
            </div>
        </form>

    </div>
</body>
</html>