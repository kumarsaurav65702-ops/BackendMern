<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
         <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>


</head>
<body>
   <div class="bg-zinc-900 h-screen w-full p-10 text-white">
    <div class="nav  bg-gray-600  w-40 p-2 text-black text-center rounded-lg mb-10">
        <a class="text-white" href="/read">Read Users</a>
    </div>
    <h1 class="text-3xl tracking-tighter mb-4">Create User</h1>
    <form action="/create" method="post">
        <input class="px-5 py-2 m-6 outline-none border-2 border-zinc-800 rounded" name="name" type="text" placeholder="name">
        <input class="px-5 py-2 m-6 outline-none border-2 border-zinc-800 rounded" name="email" type="email" placeholder="Email">
        <input class="px-5 py-2 m-6 outline-none border-2 border-zinc-800 rounded" name="image" type="text" placeholder="image url">
        <input class="bg-blue-600 px-5 py-2 rounded" type="submit" value="Create User">
    </form>
   </div>
</html>