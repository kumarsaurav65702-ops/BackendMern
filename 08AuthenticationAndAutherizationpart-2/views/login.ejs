<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="h-screen w-full bg-zinc-900 text-white p-10">
        <h1 class="text-3xl mb-10">Log In Your Account</h1>
           <form class="flex flex-col gap-3" method="post" action="/login">
            <input class="px-3 py-2 w-1/4 rounded-md bg-transparent border-2 border-zinc-800 outline-none" type="email" placeholder="email" name="email">
            <input class="px-3 py-2 w-1/4 rounded-md bg-transparent border-2 border-zinc-800 outline-none" type="password" placeholder="password" name="password">
            <input class="px-5 py-2 w-1/4 rounded-md bg-blue-500" type="submit" value="LogIn">
           </form>
     </div>
</body>
</html>